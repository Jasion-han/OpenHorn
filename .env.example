# Database
DATABASE_URL=file:./data/openhorn.db

# JWT
JWT_SECRET=your-secret-key-here

# Encryption
ENCRYPTION_KEY=your-32-byte-encryption-key

# API Keys (可选) — 也可在 UI 中按用户配置
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_OAUTH_TOKEN=
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=

# 联网搜索 (可选) — 服务端全局 Tavily Key，用户可在设置中覆盖
TAVILY_API_KEY=

# Server
PORT=3000
NODE_ENV=development

# Web (可选) — 编译期内联，默认 http://localhost:3000
NEXT_PUBLIC_API_BASE=
