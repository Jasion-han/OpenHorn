# Database
DATABASE_URL=file:./data/openhorn.db

# 附件等运行时数据的存储根目录 (可选) — 默认项目内 data 目录
OPENHORN_DATA_DIR=

# JWT
JWT_SECRET=your-secret-key-here

# Encryption
ENCRYPTION_KEY=your-32-byte-encryption-key

# API Keys (可选) — 也可在 UI 中按用户配置
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_OAUTH_TOKEN=
# DeepSeek: 仅透传给 Agent CLI 子进程，服务端无一等凭据检测
DEEPSEEK_API_KEY=
# Google/Gemini: 服务端优先读 GEMINI_API_KEY，未设置时回退到 GOOGLE_API_KEY
GOOGLE_API_KEY=
GEMINI_API_KEY=

# Anthropic 自定义网关地址 (可选) — 透传给 Agent 运行时的 ANTHROPIC_BASE_URL
ANTHROPIC_BASE_URL=

# 联网搜索 (可选) — 服务端全局 Tavily Key，用户可在设置中覆盖
TAVILY_API_KEY=

# Server
PORT=3000
NODE_ENV=development

# Web (可选) — 编译期内联，默认 http://localhost:3000
NEXT_PUBLIC_API_BASE=
