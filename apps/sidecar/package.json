{
  "name": "sidecar",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist",
    "compile:mac": "bun build src/index.ts --compile --outfile dist/openhorn-sidecar",
    "compile:tauri:darwin-arm64": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile ../desktop/src-tauri/binaries/openhorn-sidecar-aarch64-apple-darwin",
    "compile:tauri:darwin-x64": "bun build src/index.ts --compile --target=bun-darwin-x64 --outfile ../desktop/src-tauri/binaries/openhorn-sidecar-x86_64-apple-darwin",
    "compile:tauri:linux-x64": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile ../desktop/src-tauri/binaries/openhorn-sidecar-x86_64-unknown-linux-gnu",
    "compile:tauri:linux-arm64": "bun build src/index.ts --compile --target=bun-linux-arm64 --outfile ../desktop/src-tauri/binaries/openhorn-sidecar-aarch64-unknown-linux-gnu",
    "compile:tauri:host": "bash scripts/compile-tauri-host.sh",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "e2e:smoke": "bun run scripts/e2e-smoke.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.71",
    "@earendil-works/pi-agent-core": "^0.74.0",
    "@earendil-works/pi-ai": "^0.74.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "adapters": "workspace:*",
    "shared": "workspace:*",
    "turndown": "^7.2.4",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/turndown": "^5.0.6",
    "bun-types": "^1.2.0",
    "typescript": "^5.0.0"
  }
}
