{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Baseline permissions plus sidecar/dialog access for the desktop agent runtime",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "openhorn-sidecar",
          "sidecar": true,
          "args": []
        }
      ]
    },
    "shell:allow-kill",
    "shell:allow-open"
  ]
}
